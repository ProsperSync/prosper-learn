{
  "expo": {
    "name": "Prosper Learn",
    "slug": "prosper-learn",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#4CAF50"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.prospersync.learn"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4CAF50"
      },
      "package": "com.prospersync.learn",
      "versionCode": 1,
      "targetSdkVersion": 34
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "prosper-learn",
    "plugins": [
      "expo-router",
      [
        "@sentry/react-native/expo",
        {
          "organization": "prosper-sync",
          "project": "prosper-learn"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#4CAF50"
        }
      ]
    ],
    "extra": {
      "privacyPolicyUrl": "https://prospersync.github.io/prosper-learn/privacy-policy.html",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "25cd89b4-baf9-4c2a-a208-bdb9a5b1b09e"
      }
    },
    "owner": "danielgaio"
  }
}
