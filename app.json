{
  "expo": {
    "name": "Prosper Learn",
    "slug": "prosper-learn",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#4CAF50"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.prospersync.learn"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4CAF50"
      },
      "package": "com.prospersync.learn",
      "versionCode": 1,
      "targetSdkVersion": 34
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "prosper-learn",
    "plugins": ["expo-router"],
    "extra": {
      "privacyPolicyUrl": "https://prospersync.github.io/prosper-learn/privacy-policy.html"
    }
  }
}